{
  "expo": {
    "name": "SoftwareComplex",
    "slug": "SoftwareComplex",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#131370",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simulador.complex"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#131370",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.simulador.complex",
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#2622BD"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "00d9959c-6bf4-4503-b452-cd02335f98be"
      }
    },
    "owner": "withoul2"
  }
}
